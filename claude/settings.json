{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_TELEMETRY": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(pwd)",
      "Bash(diff:*)",
      "Bash(fd:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(rg:*)",
      "Bash(grep:*)",
      "Bash(awk:*)",
      "Bash(git log:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr view:*)",
      "Grep"
    ],
    "deny": [
      "CronCreate",
      "CronDelete",
      "CronList",
      "EnterPlanMode",
      "ExitPlanMode",
      "NotebookEdit",
      "PowerShell",
      "PushNotification",
      "RemoteTrigger",
      "ReportFindings",
      "ScheduleWakeup",
      "SendMessage",
      "SendUserFile",
      "ShareOnboardingGuide",
      "Workflow",
      "Bash(rm -rf:*)",
      "Bash(wget:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Read(**/.env)",
      "Read(**/.env.*)"
    ],
    "ask": []
  },
  "disableBundledSkills": true,
  "disableWorkflows": true,
  "disableRemoteControl": true,
  "disableClaudeAiConnectors": true,
  "model": "sonnet",
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "nono@always-further": true,
    "gcx@gcx-marketplace": true
  },
  "extraKnownMarketplaces": {
    "gcx-marketplace": {
      "source": {
        "source": "github",
        "repo": "grafana/gcx"
      }
    }
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Bottling",
      "Brewing",
      "Burping",
      "Carbonating",
      "Checking gravity",
      "Conditioning",
      "Crushing malt",
      "Decocting",
      "Dry Hopping",
      "Fermenting",
      "Kegging",
      "Lagering",
      "Lautering",
      "Mashing",
      "Milling",
      "Pitching yeast",
      "Racking",
      "Sparging",
      "Tapping kegs"
    ]
  },
  "tui": "fullscreen",
  "theme": "dark"
}
